{
  "rules": [
    {
      "allowed": {
        "origins": [
          "http://localhost:4200",
          "https://*.pages.dev"
        ],
        "methods": ["GET", "PUT", "HEAD"],
        "headers": ["Content-Type", "Content-Length"]
      },
      "exposeHeaders": ["ETag"],
      "maxAgeSeconds": 300
    }
  ]
}
